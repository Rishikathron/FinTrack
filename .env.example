# ================================================
# FinTrack -- Environment variables for Docker / Railway
# ================================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env
#
# NEVER commit the .env file to Git!
# ================================================

# OpenRouter API key (required for Production AI)
OPENROUTER_API_KEY=

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Image tag (useful for CI/CD)
TAG=latest
